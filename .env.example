# Test Credentials (legacy — retained for reference; the Labs dev-bypass flow
# below does not use these).
TEST_USER=your-test-email@example.com
TEST_PASSWORD=your-test-password

# Brivo Labs auth mode: 'labs' (default, production — uses the labs-auth.js SDK)
# or 'dev' (local/E2E dev-bypass — injects the token below, skips the SDK).
VITE_AUTH_MODE=dev

# Labs base URL. Override only to point at a staging/local Labs instance.
# Default when unset: https://labs.eagleeyenetworks.com
# VITE_LABS_BASE=https://labs.eagleeyenetworks.com

# Labs dev-bypass (local + E2E). Obtain a current EEN access token and the
# matching cluster base URL out-of-band; required when VITE_AUTH_MODE=dev.
VITE_DEV_EEN_TOKEN=YOUR-EEN-ACCESS-TOKEN
VITE_DEV_EEN_BASE_URL=https://api.cXXX.eagleeyenetworks.com
